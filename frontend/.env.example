# ================================================================
# InnoFaso Frontend — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# ================================================================

# URL du backend (utilisée par le proxy Vite en dev)
# En dev : laisser vide (utilise localhost:5000 par défaut)
# En prod sur Vercel/Netlify : mettre l'URL de ton backend deployé
VITE_API_URL=http://localhost:5000

# Optionnel — nom affiché dans le titre
VITE_APP_NAME=InnoFaso
